#include <iostream>
#include <string>

void preencherarray(std :: string array[], int tamanho){
    for (int i = 0; i < tamanho; i++){
        std :: cout << "Me diga os nomes da lista na posição " << i << ": ";
        std :: getline(std :: cin >> std :: ws, array[i]);
    }
}

void implementararray(std :: string array[], int tamanho){
    std :: cout << "Dados presentes no array: [";
    
    for (int i = 0; i < tamanho; i++){
        std :: cout << array[i] << " ";
    }
    std :: cout << ']';
    std :: cout << '\n';
}

int main(){
    int Tamanho = 5;
    std :: string Array[Tamanho];

    preencherarray(Array, Tamanho);
    implementararray(Array, Tamanho);

    return 0;
}
